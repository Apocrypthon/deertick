# DeerTick — copy to .env and fill in your keys

# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Discord bot (required)
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_ALERT_CHANNEL_ID=your-channel-id

# Robinhood
ROBINHOOD_USERNAME=your@email.com
ROBINHOOD_PASSWORD=yourpassword

# Coinbase Advanced Trade (Ed25519 key, newlines as \n)
COINBASE_API_KEY=organizations/xxx/apiKeys/yyy
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----

# Alpaca paper trading
ALPACA_API_KEY=PKxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxx
ALPACA_PAPER=true

# TradingView webhook
TV_WEBHOOK_SECRET=choose-a-secret-string

# ngrok (free account at ngrok.com)
NGROK_AUTHTOKEN=your-ngrok-authtoken

# Trading gates — KEEP FALSE until Alpaca paper shows profit
TRADE_ENABLED=false

# Tuning (optional)
REBALANCE_INTERVAL_SEC=300
ARB_SCAN_INTERVAL_SEC=120
ARB_MAX_TRADE_USD=50
ARB_AUTO_PCT=0.01
ARB_SHOW_MIN_PCT=0.05
ARB_SHOW_MAX_PCT=0.25
ARB_MIN_PROFIT_PCT=0.10
